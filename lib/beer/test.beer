(ns beer.test)

;; State lives in beer.test namespace as atoms.

(def *tests* (atom []))
(def *test-count* (atom 0))
(def *pass-count* (atom 0))
(def *fail-count* (atom 0))

(defn -register-test! [name tfn]
  (swap! beer.test/*tests* conj [name tfn]))

(defn -inc-test-count! []
  (swap! beer.test/*test-count* inc))

(defn -inc-pass-count! []
  (swap! beer.test/*pass-count* inc))

(defn -inc-fail-count! []
  (swap! beer.test/*fail-count* inc))

(defmacro is [expr]
  (if (and (list? expr) (= (first expr) (quote =)) (= (count expr) 3))
    ;; Special case: (is (= expected actual))
    (let* [expected-sym (gensym "expected")
           actual-sym (gensym "actual")]
      (list (quote let*) [expected-sym (nth expr 1)
                          actual-sym (nth expr 2)]
            (list (quote do)
                  (list (quote beer.test/-inc-test-count!))
                  (list (quote if) (list (quote =) expected-sym actual-sym)
                        (list (quote beer.test/-inc-pass-count!))
                        (list (quote do)
                              (list (quote beer.test/-inc-fail-count!))
                              (list (quote println) (str "FAIL: " (pr-str expr)))
                              (list (quote println) (str "  expected: ") expected-sym)
                              (list (quote println) (str "  actual:   ") actual-sym))))))
    ;; General case: (is expr)
    (list (quote do)
          (list (quote beer.test/-inc-test-count!))
          (list (quote if) expr
                (list (quote beer.test/-inc-pass-count!))
                (list (quote do)
                      (list (quote beer.test/-inc-fail-count!))
                      (list (quote println) (str "FAIL: " (pr-str expr))))))))

(defmacro deftest [name & body]
  (list (quote do)
        (list (quote def) name (list (quote fn) (quote []) (cons (quote do) body)))
        (list (quote beer.test/-register-test!) (pr-str name) name)))

(defmacro testing [description & body]
  (cons (quote do)
        (cons (list (quote println) description)
              body)))

(defn run-tests []
  (reset! beer.test/*test-count* 0)
  (reset! beer.test/*pass-count* 0)
  (reset! beer.test/*fail-count* 0)
  (println "")
  (println "Running tests...")
  (println "")
  (doseq [t @beer.test/*tests*]
    (let* [tname (nth t 0)
           tfn (nth t 1)]
      (println (str "Testing " tname))
      (try
        (tfn)
        (catch e
          (println (str "ERROR in " tname ": " (get e :message "unknown error")))
          (swap! beer.test/*fail-count* inc)))))
  (println "")
  (println (str "Ran " (count @beer.test/*tests*) " tests containing " @beer.test/*test-count* " assertions."))
  (println (str @beer.test/*pass-count* " passed, " @beer.test/*fail-count* " failed."))
  (if (= @beer.test/*fail-count* 0) 0 1))
